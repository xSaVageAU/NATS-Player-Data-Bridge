{
	"schemaVersion": 1,
	"id": "nats-player-data-bridge",
	"version": "${version}",
	"name": "NATS Player Data Bridge",
	"description": "Synchronizes player state (NBT, Stats, Advancements) across server clusters using NATS.",
	"authors": [
		"xSaVageAU"
	],
	"contact": {
		"homepage": "https://github.com/xSaVageAU/NATS-Player-Data-Bridge",
		"sources": "https://github.com/xSaVageAU/NATS-Player-Data-Bridge"
	},
	"license": "MIT",
	"icon": "assets/nats-player-data-bridge/icon.png",
	"environment": "server",
	"entrypoints": {
		"main": [
			"savage.natsplayerdata.NATSPlayerDataBridge"
		]
	},
	"mixins": [
		"nats-player-data-bridge.mixins.json"
	],
	"accessWidener": "nats-player-data-bridge.accesswidener",
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": ">=26.1",
		"java": ">=25",
		"fabric-api": "*",
		"nats-fabric": ">=1.0.0-rc.1"
